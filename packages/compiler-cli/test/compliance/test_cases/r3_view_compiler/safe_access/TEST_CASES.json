{
  "$schema": "../../test_case_schema.json",
  "cases": [
    {
      "description": "should handle safe keyed reads inside templates",
      "inputFiles": ["safe_keyed_read.ts"],
      "compilerOptions": {
        "target": "es2020"
      },
      "expectations": [
        {
          "files": [
            {
              "expected": "safe_keyed_read_template.js",
              "generated": "safe_keyed_read.js"
            }
          ],
          "failureMessage": "Incorrect template"
        }
      ]
    },
    {
      "description": "should handle safe keyed reads inside templates with legacyOptionalChaining",
      "inputFiles": ["safe_keyed_read_use_null.ts"],
      "compilationModeFilter": ["full compile", "instruction compile"],
      "compilerOptions": {
        "target": "es2020"
      },
      "expectations": [
        {
          "files": [
            {
              "expected": "safe_keyed_read_template_use_null.js",
              "generated": "safe_keyed_read_use_null.js"
            }
          ],
          "failureMessage": "Incorrect template"
        }
      ],
      "angularCompilerOptions": {
        "legacyOptionalChaining": true
      }
    },
