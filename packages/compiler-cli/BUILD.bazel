load("@aspect_rules_esbuild//esbuild:defs.bzl", "esbuild")
load("@npm2//:defs.bzl", "npm_link_all_packages")
load("//tools:defaults2.bzl", "api_golden_test", "extract_types", "npm_package", "ts_config", "ts_project")

package(default_visibility = ["//visibility:public"])

PUBLIC_TARGETS = [
    ":compiler-cli",
    "//packages/compiler-cli/private:private",
    "//packages/compiler-cli/linker:linker",
    "//packages/compiler-cli/linker/babel:babel",

    # Included for types to occur in dts files in the package.
    "//packages/compiler-cli/src/ngtsc/annotations/common:common",
    "//packages/compiler-cli/src/ngtsc/annotations/directive:directive",
    "//packages/compiler-cli/src/ngtsc/annotations:annotations",
    "//packages/compiler-cli/src/ngtsc/annotations/ng_module:ng_module",
    "//packages/compiler-cli/src/ngtsc/core:core",
    "//packages/compiler-cli/src/ngtsc/cycles:cycles",
    "//packages/compiler-cli/src/ngtsc/diagnostics:diagnostics",
    "//packages/compiler-cli/src/ngtsc/docs:docs",
    "//packages/compiler-cli/src/ngtsc/entry_point:entry_point",
    "//packages/compiler-cli/src/ngtsc/file_system:file_system",
    "//packages/compiler-cli/src/ngtsc/hmr:hmr",
    "//packages/compiler-cli/src/ngtsc/imports:imports",
    "//packages/compiler-cli/src/ngtsc/incremental:incremental",
    "//packages/compiler-cli/src/ngtsc/incremental/semantic_graph:semantic_graph",
    "//packages/compiler-cli/src/ngtsc/indexer:indexer",
    "//packages/compiler-cli/src/ngtsc/logging:logging",
    "//packages/compiler-cli/src/ngtsc/metadata:metadata",
    "//packages/compiler-cli/src/ngtsc/partial_evaluator:partial_evaluator",
    "//packages/compiler-cli/src/ngtsc/perf:perf",
    "//packages/compiler-cli/src/ngtsc/program_driver:program_driver",
    "//packages/compiler-cli/src/ngtsc/reflection:reflection",
    "//packages/compiler-cli/src/ngtsc/resource:resource",
    "//packages/compiler-cli/src/ngtsc/scope:scope",
    "//packages/compiler-cli/src/ngtsc/shims:shims",
    "//packages/compiler-cli/src/ngtsc/sourcemaps:sourcemaps",
    "//packages/compiler-cli/src/ngtsc/transform:transform",
    "//packages/compiler-cli/src/ngtsc/transform/jit:jit",
    "//packages/compiler-cli/src/ngtsc/translator:translator",
    "//packages/compiler-cli/src/ngtsc/typecheck/api:api",
    "//packages/compiler-cli/src/ngtsc/typecheck/diagnostics:diagnostics",
    "//packages/compiler-cli/src/ngtsc/typecheck/extended/api:api",
    "//packages/compiler-cli/src/ngtsc/typecheck/extended/checks/interpolated_signal_not_invoked:interpolated_signal_not_invoked",
    "//packages/compiler-cli/src/ngtsc/typecheck/extended/checks/invalid_banana_in_box:invalid_banana_in_box",
    "//packages/compiler-cli/src/ngtsc/typecheck/extended/checks/missing_control_flow_directive:missing_control_flow_directive",
    "//packages/compiler-cli/src/ngtsc/typecheck/extended/checks/missing_ngforof_let:missing_ngforof_let",
    "//packages/compiler-cli/src/ngtsc/typecheck/extended/checks/missing_structural_directive:missing_structural_directive",
    "//packages/compiler-cli/src/ngtsc/typecheck/extended/checks/nullish_coalescing_not_nullable:nullish_coalescing_not_nullable",
    "//packages/compiler-cli/src/ngtsc/typecheck/extended/checks/optional_chain_not_nullable:optional_chain_not_nullable",
    "//packages/compiler-cli/src/ngtsc/typecheck/extended/checks/skip_hydration_not_static:skip_hydration_not_static",
    "//packages/compiler-cli/src/ngtsc/typecheck/extended/checks/suffix_not_supported:suffix_not_supported",
    "//packages/compiler-cli/src/ngtsc/typecheck/extended/checks/text_attribute_not_binding:text_attribute_not_binding",
    "//packages/compiler-cli/src/ngtsc/typecheck/extended/checks/uninvoked_function_in_event_binding:uninvoked_function_in_event_binding",
    "//packages/compiler-cli/src/ngtsc/typecheck/extended/checks/uninvoked_function_in_text_interpolation:uninvoked_function_in_text_interpolation",
    "//packages/compiler-cli/src/ngtsc/typecheck/extended/checks/uninvoked_track_function:uninvoked_track_function",
    "//packages/compiler-cli/src/ngtsc/typecheck/extended/checks/unparenthesized_nullish_coalescing:unparenthesized_nullish_coalescing",
    "//packages/compiler-cli/src/ngtsc/typecheck/extended/checks/unused_let_declaration:unused_let_declaration",
    "//packages/compiler-cli/src/ngtsc/typecheck/extended:extended",
    "//packages/compiler-cli/src/ngtsc/typecheck:typecheck",
    "//packages/compiler-cli/src/ngtsc/validation:validation",
    "//packages/compiler-cli/src/ngtsc/xi18n:xi18n",
    "//packages/compiler-cli/src/ngtsc/util:util",
    "//packages/compiler-cli/src/ngtsc/typecheck/template_semantics:template_semantics",
    "//packages/compiler-cli/src/ngtsc/typecheck/template_semantics/api:api",
    "//packages/compiler-cli/src/ngtsc/shims:api",
    "//packages/compiler-cli/src/ngtsc/incremental:api",
    "//packages/compiler-cli/src/ngtsc/core:api",
    "//packages/compiler-cli/src/ngtsc/annotations/component:component",
]

npm_link_all_packages()

ts_config(
    name = "tsconfig_build",
    src = "tsconfig.json",
    deps = [
        "//:node_modules/@types/node",
        "//packages:tsconfig_build",
    ],
)

ts_config(
    name = "tsconfig_test",
    testonly = True,
    src = "tsconfig-test.json",
    deps = [
        ":tsconfig_build",
        "//:node_modules/@types/jasmine",
    ],
)

esbuild(
    name = "bundles",
    config = "esbuild.config.js",
    entry_points = [
        ":index.ts",
        "//packages/compiler-cli:src/bin/ngc.ts",
        "//packages/compiler-cli:src/bin/ng_xi18n.ts",
        "//packages/compiler-cli/linker:files",
        "//packages/compiler-cli/linker/babel:files",
        "//packages/compiler-cli/private:files",
    ],
    external = [
        "@angular/compiler",
        "typescript",
        "@babel/core",
        "reflect-metadata",
        "chokidar",
        "convert-source-map",
        "semver",
        "@jridgewell/sourcemap-codec",
        "tslib",
        "yargs",
    ],
    format = "esm",
    metafile = False,
    platform = "node",
    splitting = True,
    target = "node20",
    deps = PUBLIC_TARGETS,
)

ts_project(
    name = "compiler-cli",
    srcs = glob(
        [
            "*.ts",
            "src/**/*.ts",
        ],
        exclude = [
            "src/integrationtest/**/*.ts",
        ],
    ),
    deps = [
        "//:node_modules/@types/yargs",
        "//:node_modules/chokidar",
        "//:node_modules/reflect-metadata",
        "//:node_modules/typescript",
        "//packages/compiler",
        "//packages/compiler-cli/private",
        "//packages/compiler-cli/src/ngtsc/core",
        "//packages/compiler-cli/src/ngtsc/core:api",
        "//packages/compiler-cli/src/ngtsc/diagnostics",
        "//packages/compiler-cli/src/ngtsc/docs",
        "//packages/compiler-cli/src/ngtsc/file_system",
        "//packages/compiler-cli/src/ngtsc/incremental",
        "//packages/compiler-cli/src/ngtsc/indexer",
        "//packages/compiler-cli/src/ngtsc/logging",
        "//packages/compiler-cli/src/ngtsc/perf",
        "//packages/compiler-cli/src/ngtsc/program_driver",
        "//packages/compiler-cli/src/ngtsc/reflection",
        "//packages/compiler-cli/src/ngtsc/shims",
        "//packages/compiler-cli/src/ngtsc/transform/jit",
        "//packages/compiler-cli/src/ngtsc/translator",
        "//packages/compiler-cli/src/ngtsc/typecheck",
        "//packages/compiler-cli/src/ngtsc/typecheck/api",
        "//packages/compiler-cli/src/ngtsc/util",
    ],
)

extract_types(
    name = "api_type_definitions",
    deps = PUBLIC_TARGETS,
)

npm_package(
    srcs = [
        "package.json",
        ":bundles",
    ] + ["%s_types" % target for target in PUBLIC_TARGETS],
    package = "@angular/compiler-cli",
    tags = [
        "release-with-framework",
    ],
    visibility = [
        "//adev:__pkg__",
        "//integration:__subpackages__",
        "//modules/benchmarks:__subpackages__",
        "//modules/playground:__subpackages__",
        "//modules/ssr-benchmarks:__subpackages__",
        "//packages/compiler-cli/integrationtest:__pkg__",
        "//packages/core/test/bundling:__subpackages__",
        "//packages/core/test/playground/zone-signal-input:__pkg__",
    ],
)

api_golden_test(
    name = "error_code_api",
    data = [
        ":compiler-cli",
        "//goldens:public-api",
    ],
    entry_point = "src/ngtsc/diagnostics/src/error_code.d.ts",
    golden = "goldens/public-api/compiler-cli/error_code.api.md",
)

api_golden_test(
    name = "extended_template_diagnostic_name_api",
    data = [
        ":compiler-cli",
        "//goldens:public-api",
    ],
    entry_point = "src/ngtsc/diagnostics/src/extended_template_diagnostic_name.d.ts",
    golden = "goldens/public-api/compiler-cli/extended_template_diagnostic_name.api.md",
)

api_golden_test(
    name = "compiler_options_api",
    data = [
        ":compiler-cli",
        "//goldens:public-api",
    ],
    entry_point = "src/ngtsc/core/api/src/public_options.d.ts",
    golden = "goldens/public-api/compiler-cli/compiler_options.api.md",
)
